# Copy to .env and fill in real values. .env is git-ignored — never commit it.
# Load these at runtime via python-dotenv (see src/config.py).

# --- Data source credentials (example placeholders) ---
SCPRS_DB_URL=postgresql://user:password@host:5432/dbname
SCPRS_API_KEY=

# --- Optional: object storage for outputs ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2

# --- App settings ---
LOG_LEVEL=INFO

# --- Remote MCP per-user access tokens (local source of truth) ---
# Comma-separated label:token pairs. This is the authoritative copy you edit;
# push it to the Space secret with: deploy/hf-space/set_tokens.py
# Generate a token: python -c "import secrets; print(secrets.token_hex(24))"
# MCP_AUTH_TOKENS=alice:REPLACE_WITH_TOKEN,bob:REPLACE_WITH_TOKEN

# --- Data-refresh pipeline (HF tokens; least-privilege, one repo each) ---
# Fine-grained HF tokens for the local pipeline. The deployed Spaces use their own
# scoped secrets — these are only for running the refresh from this machine.
# Write on the serve-DB dataset — used by `python -m src.data_sync publish`
# (the Space-deploy token can't write the dataset; falls back to HF_TOKEN if unset):
# HF_WAREHOUSE_TOKEN=hf_REPLACE_WITH_scprs-warehouse-data_WRITE_TOKEN
# Read on the audit-log dataset — for ad-hoc query-log reads:
# HF_AUDIT_TOKEN=hf_REPLACE_WITH_scprs-query-log_READ_TOKEN

# --- Operational store sync (Wave 2: scprs.db in a private HF Dataset) ---
# The private dataset that holds the full operational store (scprs.db). GitHub
# Actions becomes its single writer; local dev leaves this unset and keeps using
# data/scprs.db. Seed it once from a local checkout:
#   python -m src.data_sync publish-operational --dataset munther-hasan/scprs-operational-db
# SCPRS_DATASET=munther-hasan/scprs-operational-db
# Read+write on that dataset — used by `data_sync fetch-operational` / `publish-operational`
# (falls back to HF_TOKEN if unset). In Actions this is the HF_SCPRS_TOKEN secret:
# HF_SCPRS_TOKEN=hf_REPLACE_WITH_scprs-operational-db_READWRITE_TOKEN
