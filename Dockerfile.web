# Public natural-language web app image (Gradio) over the gold warehouse.
#
# Ships the read-only query surface + NL->SQL layer + Gradio UI plus the gold
# warehouse DB baked in — no pandas/playwright/mcp. The DB is a read-only
# snapshot: to publish fresh data, rebuild the warehouse locally and rebuild this
# image. GEMINI_API_KEY is injected at deploy time (a Space secret), never baked.
#
# Build (BuildKit uses Dockerfile.web.dockerignore, which re-includes the DB):
#   docker build -f Dockerfile.web -t scprs-web .
# Run:
#   docker run -e GEMINI_API_KEY=... -p 7860:7860 scprs-web
FROM python:3.12-slim

# Least privilege: run as a non-root user.
RUN useradd --create-home --uid 10001 appuser
WORKDIR /app

COPY requirements-web.txt .
RUN pip install --no-cache-dir -r requirements-web.txt

# App code only — no data is baked in. The slim serve DB is fetched from the
# private HF Dataset (WAREHOUSE_DATASET) into /data at startup by data_sync.
COPY src/ ./src/
COPY app.py .

ENV WAREHOUSE_DB=/data/warehouse.db \
    GRADIO_SERVER_NAME=0.0.0.0 \
    GRADIO_SERVER_PORT=7860 \
    GRADIO_ANALYTICS_ENABLED=False \
    PYTHONUNBUFFERED=1
# GEMINI_API_KEY is NOT set here — provide it at deploy time (Space secret).
# WAREHOUSE_DATASET (+ HF_TOKEN) must be set for the startup DB fetch to work.

# Writable dirs for the non-root appuser (/app is root-owned): the fetched serve
# DB (/data) and the optional query-log staging dir (QUERY_LOG_DIR).
RUN mkdir -p /data /app/query_logs && chown appuser /data /app/query_logs

USER appuser
EXPOSE 7860

# Liveness against the Gradio root page.
HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:7860/').status==200 else 1)"

CMD ["python", "app.py"]
