# Remote MCP server image (deployment "Model A").
#
# Ships ONLY the read-only warehouse MCP server plus the gold warehouse DB baked
# in — no pandas/playwright, so the image stays small. The DB is a read-only
# snapshot: to publish fresh data, rebuild the warehouse locally and rebuild this
# image. MCP_AUTH_TOKEN is injected at deploy time (a Fly secret), never baked in.
#
# Build (BuildKit uses Dockerfile.mcp.dockerignore, which re-includes the DB):
#   docker build -f Dockerfile.mcp -t scprs-mcp .
# Run:
#   docker run -e MCP_AUTH_TOKEN=$(openssl rand -hex 24) -p 8000:8000 scprs-mcp
FROM python:3.12-slim

# Least privilege: run as a non-root user.
RUN useradd --create-home --uid 10001 appuser
WORKDIR /app

COPY requirements-mcp.txt .
RUN pip install --no-cache-dir -r requirements-mcp.txt

# Server code only — no data is baked in. The slim serve DB is fetched from the
# private HF Dataset (WAREHOUSE_DATASET) into /data at startup by data_sync.
COPY src/ ./src/

ENV WAREHOUSE_DB=/data/warehouse.db \
    HOST=0.0.0.0 \
    PORT=8000 \
    PYTHONUNBUFFERED=1 \
    MPLCONFIGDIR=/tmp/mpl \
    REPORTS_DIR=/app/reports \
    QUERY_LOG_DIR=/app/query_logs
# MCP_AUTH_TOKEN is NOT set here — provide it at deploy time. The tool-call audit
# log stays off until QUERY_LOG_DATASET (+ an HF write token in HF_TOKEN) is set.
# WAREHOUSE_DATASET (+ HF_TOKEN) must be set for the startup DB fetch to work.

# Writable dirs for the non-root appuser (/app is root-owned): the fetched serve
# DB (/data), generate_report output (REPORTS_DIR), and the audit log (QUERY_LOG_DIR).
RUN mkdir -p /data /app/reports /app/query_logs \
    && chown appuser /data /app/reports /app/query_logs

USER appuser
EXPOSE 8000

# Liveness against the unauthenticated /healthz path.
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/healthz').status==200 else 1)"

CMD ["python", "-m", "src.mcp_server", "http"]
